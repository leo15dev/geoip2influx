      "panel-7": {
        "kind": "Panel",
        "spec": {
          "id": 7,
          "title": "📈 即時網路流量與延遲趨勢 (Traffic & Latency Trend)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "${datasource}"
                      },
                      "spec": {
                        "alias": "$col",
                        "query": "SELECT sum(\"bytes_sent\") AS \"網路流量\" FROM \"nginx_access_logs\" WHERE $timeFilter AND \"host\" =~ /^$host$/ GROUP BY time($__interval) fill(0)",
                        "rawQuery": true,
                        "resultFormat": "time_series"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "influxdb",
                      "version": "v0",
                      "datasource": {
                        "name": "${datasource}"
                      },
                      "spec": {
                        "alias": "$col",
                        "query": "SELECT mean("request_time") AS "網頁響應時間(秒)", mean("connect_time") AS "Upstream響應時間(秒)" FROM "nginx_access_logs" WHERE $timeFilter AND "host" =~ /^$host$/ AND "status" != '101' AND "url" !~ /ws|stream|socket|live/ AND "request_time" < 30 GROUP BY time($__interval) fill(null)",
                        "rawQuery": true,
                        "resultFormat": "time_series"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                }
              ],
